# Google Generative AI API Key
# Get your API key from: https://makersuite.google.com/app/apikey
REACT_APP_GOOGLE_API_KEY=your_google_api_key_here

# LinkedIn OAuth (from LinkedIn Developer Portal → your app → Auth)
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# NewsAPI (must use REACT_APP_ prefix so Create React App embeds it in the bundle)
# Get a key: https://newsapi.org/register
REACT_APP_NEWSAPI=your_newsapi_key_here
#
# Android APK: the WebView loads https://localhost — NewsAPI blocks that origin (CORS). The app uses your
# Firebase Hosting URL + Cloud Function `newsApi` as a proxy. Set the SAME key on the server:
#   Firebase Console → Build → Functions → your project → Configuration → Environment variables
#   Add NEWSAPI_KEY (or REACT_APP_NEWSAPI) = your NewsAPI key, then deploy: firebase deploy --only functions,hosting
#
# Optional: if your Hosting URL is not deitedatabase.web.app, set it here (no trailing slash):
# REACT_APP_NEWS_PROXY_ORIGIN=https://your-project.web.app

# Backend-only option: call Cloud Function `newsApi` directly (bypasses Hosting rewrites).
# Set this to the exact deployed URL of the function, then rebuild.
# REACT_APP_NEWSAPI_FUNCTION_URL=https://<region>-<project>.cloudfunctions.net/newsApi
