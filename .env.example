# Create React App only exposes variables prefixed with REACT_APP_ to the browser build

REACT_APP_OPENAI_API_KEY=your_openai_api_key_here
REACT_APP_GROK_API_KEY=your_grok_api_key_here
REACT_APP_GOOGLE_API_KEY=your_google_api_key_here

# LinkedIn OAuth (do not commit; keep .env in .gitignore)
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# NewsAPI (https://newsapi.org/) — CRA only injects REACT_APP_* into the browser bundle
# For `npm start`, `src/setupProxy.js` also reads NEWSAPI_KEY (see that file).
# Optional: REACT_APP_NEWS_PROXY_ORIGIN, REACT_APP_NEWSAPI_FUNCTION_URL — see comments in older setups or Firebase docs.
REACT_APP_NEWSAPI=your_newsapi_key_here
NEWSAPI_KEY=your_newsapi_key_here
REACT_APP_NEWSAPI2=your_second_newsapi_key_here

# World News API (https://worldnewsapi.com/) — CRA injects REACT_APP_* into the browser bundle
REACT_APP_WORLDNEWS_API_KEY=your_worldnews_api_key_here
REACT_APP_WORLDNEWS_API_2=your_second_worldnews_api_key_here
WORLDNEWS_API_KEY=your_worldnews_api_key_here

# GNews (https://gnews.io/) — CRA injects REACT_APP_* into the browser bundle
REACT_APP_GNEWS_API_KEY=your_gnews_api_key_here
REACT_APP_GNEWS_API_2=your_second_gnews_api_key_here
GNEWS_API_KEY=your_gnews_api_key_here

# Thenews API — CRA injects REACT_APP_* into the browser bundle (API tokens; wire provider URL in code)
REACT_APP_THENEWS_API_TOKEN=your_thenews_api_token_here
REACT_APP_THENEWS_API_2=your_second_thenews_api_token_here
THENEWS_API_TOKEN=your_thenews_api_token_here
