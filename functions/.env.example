# LinkedIn OAuth – used by Firebase Functions (token exchange + share API)
# Copy to .env and fill in. For production, also set these in Firebase Console → Functions → Environment variables.

LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here

# NewsAPI – Android/Capacitor WebView cannot call newsapi.org from https://localhost (CORS). Proxy uses this key.
# Set NEWSAPI_KEY in Firebase Console → Functions → Environment variables (same value as REACT_APP_NEWSAPI in the app).
NEWSAPI_KEY=your_newsapi_key_here
